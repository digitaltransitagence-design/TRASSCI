# =============================================================================
# Copier ce fichier vers .env.local et renseigner les valeurs.
# Ne jamais commiter .env.local — les secrets restent sur votre machine / Vercel.
# =============================================================================

# -----------------------------------------------------------------------------
# Insforge (base de données API)
# Dashboard → Connect Project : URL du projet + clé API serveur (ik_…)
# -----------------------------------------------------------------------------
INSFORGE_API_URL=https://VOTRE_SOUS_DOMAINE.eu-central.insforge.app
INSFORGE_API_KEY=ik_VOTRE_CLE_API_SERVEUR

# Ancien nom supporté par le code (équivalent à INSFORGE_API_KEY si besoin)
# INSFORGE_ANON_KEY=

# Délai max par requête vers Insforge (ms), défaut 20000 — évite d’attendre indéfiniment
# INSFORGE_FETCH_TIMEOUT_MS=20000

# -----------------------------------------------------------------------------
# Admin (/admin) — session et authentification
# Générer une longue chaîne aléatoire (ex. PowerShell / openssl rand -base64 32)
# -----------------------------------------------------------------------------
ADMIN_SECRET=
# Optionnel : signature dédiée aux cookies admin (sinon ADMIN_SECRET est utilisé)
# ADMIN_SESSION_SECRET=

# -----------------------------------------------------------------------------
# Webhooks — notification à chaque changement de statut colis (optionnel)
# -----------------------------------------------------------------------------
# NOTIFICATION_WEBHOOK_URL=https://...
# NOTIFICATION_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# NextAuth — espace client (/client)
# En local : NEXTAUTH_URL=http://localhost:3000
# En prod (Vercel) : l’URL exacte du site, ex. https://trassci.vercel.app (sans slash final)
# Obligatoire en prod : NEXTAUTH_SECRET (ex. openssl rand -base64 32)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (optionnel) — si les deux sont vides, seule la connexion e-mail / mot de passe est proposée
# https://console.cloud.google.com/apis/credentials — type « Application Web » (pas « Bureau »)
#
# Erreur Google « redirect_uri_mismatch » : l’URI dans la console doit être EXACTEMENT la même
# que celle utilisée par l’app. Définissez NEXTAUTH_URL sur Vercel = URL où les utilisateurs
# ouvrent le site (ex. https://trassci.vercel.app sans slash final), puis dans Google Cloud :
#   URI de redirection autorisés → https://trassci.vercel.app/api/auth/callback/google
# Origines JavaScript autorisées → https://trassci.vercel.app
# En local, ajoutez aussi : http://localhost:3000/api/auth/callback/google
# Déploiement preview Vercel (autre sous-domaine) : ajoutez une ligne par URL ou testez sur l’URL prod.
# GET /api/client/auth-status renvoie googleRedirectUri pour copier la valeur attendue côté serveur.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Resend — e-mails (guide client, etc.)
# https://resend.com/api-keys | https://resend.com/domains
#
# Sans domaine vérifié : Resend n’autorise l’expéditeur de test (ex. onboarding@resend.dev)
# qu’aux envois vers l’adresse e-mail du compte Resend. Pour tout le monde : vérifiez un
# domaine sur resend.com/domains puis RESEND_FROM = Nom <vous@votredomaine.com>
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_VOTRE_CLE
# RESEND_FROM — pas de guillemets. En prod : adresse sur un domaine vérifié chez Resend.
# RESEND_FROM=Trass CI <onboarding@resend.dev>
# RESEND_REPLY_TO=

# -----------------------------------------------------------------------------
# Google Gemini — assistant emballage, rapports IA (optionnel)
# https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
