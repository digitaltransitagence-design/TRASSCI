# Copier vers .env.local — ne pas commiter les secrets.

# Insforge — onglet « Connect Project » du dashboard
# - Project URL → INSFORGE_API_URL (sans slash final)
# - API Key (commence par ik_) → INSFORGE_API_KEY  ← utiliser CELLE-CI pour l’API serveur
# - « Anon Key » (JWT eyJ…) → ne pas mettre ici (ce n’est pas la même chose)
INSFORGE_API_URL=https://VOTRE_APPKEY.eu-central.insforge.app
INSFORGE_API_KEY=ik_VOTRE_CLE
# Ancien nom (équivalent si vous l’utilisez déjà) :
# INSFORGE_ANON_KEY=ik_VOTRE_CLE

# Obligatoire en production : code serveur + signature des cookies de session admin.
# Après migration sql/migration_v4_admin_rbac.sql : créer le 1er compte sur /admin/login (écran « Premier administrateur »).
# Optionnel : clé dédiée aux cookies (sinon ADMIN_SECRET sert aussi à signer).
# ADMIN_SECRET=
# ADMIN_SESSION_SECRET=

# Webhook JSON à chaque changement de statut colis (Make, Zapier, votre bridge SMS/WhatsApp)
# NOTIFICATION_WEBHOOK_URL=https://...
# NOTIFICATION_WEBHOOK_SECRET=

# NextAuth — espace client (/client) : Google OAuth + e-mail / mot de passe
# Local : NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_URL=https://votre-domaine.com
# NEXTAUTH_SECRET=générez_une_chaîne_longue_aléatoire
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=

# Resend — e-mails transactionnels (guide client, etc.)
# 1) Clé API : https://resend.com/api-keys
# 2) Domaine vérifié pour l'expéditeur (prod) : https://resend.com/domains
# 3) Suivi des envois (aperçu, texte, HTML, événements) : https://resend.com/emails
#    (voir https://resend.com/docs/dashboard/emails/introduction )
# Développement : RESEND_FROM peut rester "Trass CI <onboarding@resend.dev>" (expéditeur de test Resend).
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Trass CI <notifications@votredomaine.com>
# Optionnel — adresse de réponse (Reply-To)
# RESEND_REPLY_TO=

# Google Gemini (assistant emballage, trafic, rapport admin)
GEMINI_API_KEY=
# Optionnel — défaut : gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
