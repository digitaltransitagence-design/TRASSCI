# Copier vers .env.local — ne pas commiter les secrets.

# Insforge — copier URL + clé depuis le dashboard du projet ou .insforge/project.json (après npx @insforge/cli link)
# L’URL doit être celle du backend (ex. https://xxxxx.eu-central.insforge.app) sans slash final.
INSFORGE_API_URL=https://VOTRE_APPKEY.eu-central.insforge.app
# Clé ik_… (une seule des deux lignes suffit)
INSFORGE_ANON_KEY=ik_VOTRE_CLE
# INSFORGE_API_KEY=ik_VOTRE_CLE

# Optionnel : protège PUT /api/admin/rules et PATCH partenaires (header x-admin-secret côté client)
# ADMIN_SECRET=

# Google Gemini (assistant emballage, trafic, rapport admin)
GEMINI_API_KEY=
# Optionnel — défaut : gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
